# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment files — secrets never enter git (spec §7.4)
.env
.env.*

# Generated synthetic datasets (regenerable via npm run seed:generate)
seed/output/

# Root-level dev-data/ is an unused duplicate of the committed public/dev-data/.
# The app serves demo data from public/dev-data/; ignore the root copy so it
# never gets re-committed. (Only the leading-slash path is ignored — public/dev-data
# stays tracked.)
/dev-data/

# Real athlete data must never enter the repository (spec §8, §14)
*.real.csv
data-real/

coverage/
